            if library.login("библиотекарь", name):
                show_librarian_menu(library)
        
        elif choice == "2":
            name = input("введите ваше имя: ").strip()
            if library.login("пользователь", name):
                show_user_menu(library, name)
        
        elif choice == "3":
            library.show_raw_bytes()
            print("\n вызвать байты")
            break

        elif choice == "0":
            library.save_data()
            print("\n пока")
            break

        else:
            print("выберите от 1 до 3 или 0")

if __name__ == "__main__":
    main()
